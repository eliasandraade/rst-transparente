# ─── Banco de dados (PostgreSQL via Railway) ──────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-secret-aqui-minimo-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudinary (storage de PDFs) ────────────────────────────────────────────
# Obtenha em: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

# ─── Admin inicial (usado pelo seed) ─────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@condominio.com"
SEED_ADMIN_PASSWORD="senha-segura-aqui"
SEED_ADMIN_NAME="Administrador"
