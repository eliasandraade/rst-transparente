// Prisma Schema — Portal da Transparência
// Condomínio Residencial Santíssima Trindade

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Usuários da área administrativa ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(CONSELHO)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  MASTER
  SINDICO
  GESTAO
  CONSELHO
}

// ─── Categorias financeiras ───────────────────────────────────────────────────

model Categoria {
  id          String         @id @default(cuid())
  nome        String
  tipo        TipoLancamento
  cor         String         @default("#64748B") // hex para gráficos
  ativo       Boolean        @default(true)
  ordem       Int            @default(0)
  lancamentos Lancamento[]
  createdAt   DateTime       @default(now())

  @@map("categorias")
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

// ─── Lançamentos financeiros (receitas e despesas) ────────────────────────────

model Lancamento {
  id          String           @id @default(cuid())
  tipo        TipoLancamento
  categoriaId String
  categoria   Categoria        @relation(fields: [categoriaId], references: [id])
  descricao   String
  valor       Decimal          @db.Decimal(12, 2)
  data        DateTime         @db.Date
  fornecedor  String?
  observacoes String?
  periodo     String           // "2025-03" (YYYY-MM)
  status      StatusPublicacao @default(RASCUNHO)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([periodo])
  @@index([tipo])
  @@index([status])
  @@map("lancamentos")
}

enum StatusPublicacao {
  RASCUNHO
  PUBLICADO
}

// ─── Pareceres do Conselho Fiscal ─────────────────────────────────────────────

model Parecer {
  id              String           @id @default(cuid())
  periodoRef      String           // "2025-03" (YYYY-MM)
  titulo          String
  texto           String?          @db.Text
  arquivoUrl      String?          // URL do PDF no Cloudinary
  arquivoNome     String?          // Nome original do arquivo
  dataEmissao     DateTime         @db.Date
  membrosConselho String?          // Nomes separados por ponto-e-vírgula
  status          StatusPublicacao @default(RASCUNHO)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([periodoRef])
  @@index([status])
  @@map("pareceres")
}

// ─── Planilhas para download ──────────────────────────────────────────────────

model PlanilhaDownload {
  id          String   @id @default(cuid())
  periodo     String   // "YYYY-MM"
  arquivoUrl  String
  arquivoNome String
  createdAt   DateTime @default(now())

  @@index([periodo])
  @@map("planilhas_download")
}

// ─── Avisos e informativos ────────────────────────────────────────────────────

model Aviso {
  id        String           @id @default(cuid())
  titulo    String
  corpo     String           @db.Text
  fixado    Boolean          @default(false)
  status    StatusPublicacao @default(RASCUNHO)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@map("avisos")
}

// ─── Obras e melhorias (seção Gestão) ────────────────────────────────────────

model Obra {
  id           String      @id @default(cuid())
  titulo       String
  descricao    String?     @db.Text
  orcamento    Decimal?    @db.Decimal(12, 2)
  gasto        Decimal?    @db.Decimal(12, 2)
  status       StatusObra  @default(PLANEJADO)
  progresso    Int         @default(0)  // 0–100
  dataInicio   DateTime?   @db.Date
  dataPrevista DateTime?   @db.Date
  imagemUrl    String?
  publicado    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("obras")
}

enum StatusObra {
  PLANEJADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// ─── Propostas dos moradores ──────────────────────────────────────────────────

model Proposta {
  id        String         @id @default(cuid())
  texto     String         @db.Text
  nome      String?
  unidade   String?
  status    StatusProposta @default(PENDENTE)
  resposta  String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("propostas")
}

enum StatusProposta {
  PENDENTE
  ANALISANDO
  RESPONDIDA
  ARQUIVADA
}

// ─── Enquetes ─────────────────────────────────────────────────────────────────

model Enquete {
  id       String           @id @default(cuid())
  pergunta String
  tipo     TipoEnquete      @default(UNICA)
  status   StatusPublicacao @default(RASCUNHO)
  dataFim  DateTime?
  opcoes   OpcaoEnquete[]
  votos    VotoEnquete[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
  @@map("enquetes")
}

enum TipoEnquete {
  UNICA
  MULTIPLA
}

model OpcaoEnquete {
  id        String        @id @default(cuid())
  enqueteId String
  enquete   Enquete       @relation(fields: [enqueteId], references: [id], onDelete: Cascade)
  texto     String
  ordem     Int           @default(0)
  votos     VotoEnquete[]

  @@map("opcoes_enquete")
}

model VotoEnquete {
  id        String       @id @default(cuid())
  enqueteId String
  enquete   Enquete      @relation(fields: [enqueteId], references: [id], onDelete: Cascade)
  opcaoId   String
  opcao     OpcaoEnquete @relation(fields: [opcaoId], references: [id], onDelete: Cascade)
  ip        String
  createdAt DateTime     @default(now())

  @@unique([enqueteId, opcaoId, ip])
  @@map("votos_enquete")
}

// ─── Membros da gestão (página Quem Somos) ────────────────────────────────────

model Membro {
  id        String   @id @default(cuid())
  nome      String
  cargo     String
  descricao String?  @db.Text
  fotoUrl   String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("membros")
}

// ─── Configuração do portal ───────────────────────────────────────────────────

model ConfigPortal {
  id             String   @id @default(cuid())
  nomeCondominio String   @default("Condomínio Residencial Santíssima Trindade")
  cnpj           String?
  endereco       String?
  logoUrl        String?
  periodoAtivo   String   @default("") // Período padrão exibido nas páginas públicas
  updatedAt      DateTime @updatedAt

  @@map("config_portal")
}
